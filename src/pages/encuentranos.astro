---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Ubicacion from '../components/Ubicacion.astro';
import { url } from '../data/config';
---

<BaseLayout
  title="Encuéntranos · Altamira GCP"
  description="Estamos en C. Rosa de Luxemburgo, 46100 Burjassot. Cómo llegar, horarios, mapa y contacto directo por WhatsApp si te pierdes."
>
  <PageHero
    eyebrow="Encuéntranos"
    title="Cómo llegar"
    subtitle="Estamos en una zona discreta. Si te pierdes, escríbenos."
  />

  <Ubicacion />

  <section class="py-16 bg-cream border-t border-charcoal/5">
    <div class="container mx-auto px-6 text-center">
      <p class="text-charcoal/70 mb-4">¿Reservas con antelación?</p>
      <a
        href={url('/reservar/')}
        class="inline-flex items-center gap-2 bg-tropical-mango hover:bg-tropical-tierra text-charcoal hover:text-cream font-bold px-8 py-4 rounded-full transition-all"
      >
        Reservar mesa
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
