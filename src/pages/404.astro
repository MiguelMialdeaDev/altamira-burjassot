---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../data/config';
---

<BaseLayout title="Página no encontrada · Altamira GCP">
  <section class="min-h-[70vh] flex items-center bg-cream py-20">
    <div class="container mx-auto px-6 max-w-2xl text-center">
      <p class="font-display text-9xl font-black text-tropical-mango mb-4">404</p>
      <h1 class="font-display text-3xl font-bold text-charcoal mb-4">
        Esta página no existe
      </h1>
      <p class="text-charcoal/70 mb-10">
        Pero hay otras que sí.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={url('/')}
          class="inline-flex items-center justify-center bg-charcoal hover:bg-tropical-tierra text-white font-bold px-6 py-3 rounded-full transition-all"
        >
          Volver al inicio
        </a>
        <a
          href={url('/carta/')}
          class="inline-flex items-center justify-center border border-charcoal text-charcoal hover:bg-charcoal hover:text-white font-bold px-6 py-3 rounded-full transition-all"
        >
          Ver la carta
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
