---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Carta from '../components/Carta.astro';
import { url } from '../data/config';
---

<BaseLayout
  title="Carta · Altamira GCP"
  description="Cachapas, arepas, tequeños, empanadas y batidos naturales. Cocina venezolana auténtica en Burjassot. Producto fresco, recetas honestas."
>
  <PageHero
    eyebrow="La carta"
    title="Lo que cocinamos"
  />

  <Carta />

  <section class="py-16 bg-cream border-t border-charcoal/5">
    <div class="container mx-auto px-6 text-center">
      <p class="text-charcoal/70 mb-4">¿Listo para venir?</p>
      <a
        href={url('/reservar/')}
        class="inline-flex items-center gap-2 bg-tropical-mango hover:bg-tropical-tierra text-charcoal hover:text-cream font-bold px-8 py-4 rounded-full transition-all"
      >
        Reservar mesa
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
