---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Reservar from '../components/Reservar.astro';
import { url } from '../data/config';
---

<BaseLayout
  title="Reservar · Altamira GCP"
  description="Reserva tu mesa en Altamira GCP, restaurante venezolano en Burjassot. Por WhatsApp o llamando al 628 15 05 50. Respuesta rápida."
>
  <PageHero
    eyebrow="Reserva tu mesa"
    title="Ven a probar Venezuela"
    subtitle="Somos pequeños y los fines de semana se llena. Avísanos."
  />

  <Reservar />

  <section class="py-16 bg-cream border-t border-charcoal/5">
    <div class="container mx-auto px-6 text-center">
      <p class="text-charcoal/70 mb-4">¿No conoces aún la carta?</p>
      <a
        href={url('/carta/')}
        class="inline-flex items-center gap-2 bg-tropical-mango hover:bg-tropical-tierra text-charcoal hover:text-cream font-bold px-8 py-4 rounded-full transition-all"
      >
        Ver la carta
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
