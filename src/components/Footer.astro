---
import { RESTAURANT } from '../data/config';
const año = new Date().getFullYear();
---

<footer class="bg-charcoal text-cream py-12">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <h3 class="font-display text-2xl font-black mb-2">{RESTAURANT.name}</h3>
        <p class="text-cream/70 text-sm mb-4">{RESTAURANT.tagline}</p>
        <div class="flex h-6 rounded-md overflow-hidden w-24 shadow-md">
          <div class="w-1/3 bg-venezuela-yellow"></div>
          <div class="w-1/3 bg-venezuela-blue"></div>
          <div class="w-1/3 bg-venezuela-red"></div>
        </div>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-display text-lg font-bold mb-4">Contacto</h4>
        <ul class="space-y-2 text-cream/80 text-sm">
          <li>📍 {RESTAURANT.address}</li>
          <li>📮 {RESTAURANT.postalCode} {RESTAURANT.city}</li>
          <li>
            📞 <a href={`tel:${RESTAURANT.phone}`} class="hover:text-tropical-mango transition-colors">{RESTAURANT.phoneDisplay}</a>
          </li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-display text-lg font-bold mb-4">También en</h4>
        <ul class="space-y-2 text-cream/80 text-sm">
          <li><a href={RESTAURANT.links.justeat} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">Just Eat</a></li>
          <li><a href={RESTAURANT.links.ubereats} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">Uber Eats</a></li>
          <li><a href={RESTAURANT.links.tripadvisor} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">TripAdvisor</a></li>
          <li><a href={RESTAURANT.links.googleMaps} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">Google Maps</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-cream/10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-cream/50 text-sm">
      <p>© {año} {RESTAURANT.name}. Todos los derechos reservados.</p>
      <p class="text-xs">
        Hecho con 💛 desde Burjassot
      </p>
    </div>
  </div>
</footer>
