---
import FlagVE from './FlagVE.astro';
import { RESTAURANT, url, SECTIONS } from '../data/config';
const año = new Date().getFullYear();
---

<footer class="bg-charcoal text-cream py-16">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <h3 class="font-display text-2xl font-black mb-2">{RESTAURANT.name}</h3>
        <p class="text-cream/70 text-sm mb-4">{RESTAURANT.tagline}</p>
        <FlagVE class="h-6 w-24 rounded-md overflow-hidden shadow-md" />
      </div>

      <!-- Navegación -->
      <div>
        <h4 class="font-display text-lg font-bold mb-4">Navegación</h4>
        <ul class="space-y-2 text-cream/80 text-sm">
          {SECTIONS.map(section => (
            <li>
              <a href={url(section.path)} class="hover:text-tropical-mango transition-colors">
                {section.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-display text-lg font-bold mb-4">Contacto</h4>
        <ul class="space-y-2 text-cream/80 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-tropical-mango" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>{RESTAURANT.address}<br />{RESTAURANT.postalCode} {RESTAURANT.city}</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0 text-tropical-mango" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <a href={`tel:${RESTAURANT.phone}`} class="hover:text-tropical-mango transition-colors">{RESTAURANT.phoneDisplay}</a>
          </li>
        </ul>
      </div>

      <!-- También en -->
      <div>
        <h4 class="font-display text-lg font-bold mb-4">También en</h4>
        <ul class="space-y-2 text-cream/80 text-sm">
          <li><a href={RESTAURANT.links.glovo} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">Glovo</a></li>
          <li><a href={RESTAURANT.links.ubereats} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">Uber Eats</a></li>
          <li><a href={RESTAURANT.links.tripadvisor} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">TripAdvisor</a></li>
          <li><a href={RESTAURANT.links.googleMaps} target="_blank" rel="noopener" class="hover:text-tropical-mango transition-colors">Google Maps</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-cream/10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-cream/50 text-sm">
      <p>© {año} {RESTAURANT.name}. Todos los derechos reservados.</p>
      <p class="text-xs">
        Hecho desde Burjassot
      </p>
    </div>
  </div>
</footer>
