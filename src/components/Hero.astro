---
import FlagVE from './FlagVE.astro';
import { RESTAURANT, whatsappLink, url } from '../data/config';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const cachapaImg = `${base}arepas-altamira.jpg`;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden bg-gradient-to-br from-tropical-jungla via-tropical-tierra to-charcoal">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.04]"
       style="background-image: radial-gradient(circle, #F4A261 1px, transparent 1px); background-size: 30px 30px;">
  </div>

  <!-- Foto real del restaurante (arepas, de su galeria oficial) -->
  <div class="absolute inset-0">
    <div class="w-full h-full bg-cover bg-center" style={`background-image: url('${cachapaImg}')`}></div>
  </div>

  <!-- Overlay suave para legibilidad sin tapar la cachapa -->
  <div class="absolute inset-0 bg-gradient-to-b from-charcoal/60 via-charcoal/55 to-charcoal/75"></div>

  <div class="relative z-20 container mx-auto px-6 py-20 md:py-28 text-center">
    <div class="max-w-3xl mx-auto">
      <!-- Badge bandera -->
      <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full pl-2 pr-4 py-1.5 mb-8 animate-fade-up">
        <FlagVE class="h-5 w-8 rounded-full overflow-hidden shadow-md" />
        <span class="text-white/90 text-sm font-medium">Cocina venezolana · Burjassot</span>
      </div>

      <h1 class="font-display text-6xl md:text-8xl font-black text-cream leading-[1.05] mb-6 animate-fade-up" style="text-shadow: 0 2px 12px rgba(0,0,0,.55), 0 1px 3px rgba(0,0,0,.7); animation-delay: 0.1s">
        Altamira
      </h1>

      <p class="text-tropical-mango text-xl md:text-2xl font-light italic mb-4 animate-fade-up" style="text-shadow: 0 2px 12px rgba(0,0,0,.55), 0 1px 3px rgba(0,0,0,.7); animation-delay: 0.2s">
        {RESTAURANT.tagline}
      </p>

      <p class="text-cream/80 text-base md:text-lg max-w-xl mx-auto mb-10 leading-relaxed animate-fade-up" style="animation-delay: 0.3s">
        Recetas familiares traídas de Caracas. Hechas a mano, cada día, con el cariño de casa.
      </p>

      <!-- Encuéntranos en Google (neutro, sin cifras inventadas) -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-12 animate-fade-up" style="animation-delay: 0.4s">
        <a
          href={RESTAURANT.links.googleMaps}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 bg-white/5 hover:bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 text-white/80 hover:text-white text-sm transition-colors"
        >
          <svg class="w-4 h-4 text-tropical-mango" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          Encuéntranos en Google
        </a>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up" style="animation-delay: 0.5s">
        <a
          href={url('/reservar/')}
          class="inline-flex items-center justify-center gap-2 bg-tropical-mango hover:bg-tropical-mango/90 text-charcoal font-bold px-8 py-4 rounded-full shadow-2xl hover:shadow-tropical-mango/50 transition-all duration-300 hover:-translate-y-0.5"
        >
          Reservar mesa
        </a>
        <a
          href={url('/historia/')}
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/30 text-white font-medium px-8 py-4 rounded-full transition-all duration-300"
        >
          Conoce nuestra historia
        </a>
      </div>

      <p class="text-white/50 text-xs mt-12 animate-fade-up flex items-center justify-center gap-2" style="animation-delay: 0.6s">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {RESTAURANT.address} · {RESTAURANT.city}
      </p>
    </div>
  </div>
</section>
