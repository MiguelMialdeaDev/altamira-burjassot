---
/**
 * Hero compacto para páginas internas (no homepage).
 * Soluciona el problema de "todas las páginas con el mismo hero gigante".
 */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<section class="relative bg-gradient-to-br from-tropical-jungla via-tropical-tierra to-charcoal py-20 md:py-28 overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]"
       style="background-image: radial-gradient(circle, #F4A261 1px, transparent 1px); background-size: 30px 30px;">
  </div>

  <div class="container mx-auto px-6 relative z-10 text-center">
    {eyebrow && (
      <p class="text-tropical-mango font-medium tracking-widest uppercase text-sm mb-3 animate-fade-up">
        {eyebrow}
      </p>
    )}
    <h1 class="font-display text-4xl md:text-6xl font-black text-cream leading-tight animate-fade-up" style="animation-delay: 0.1s">
      {title}
    </h1>
    {subtitle && (
      <p class="text-cream/70 text-lg md:text-xl mt-4 max-w-2xl mx-auto animate-fade-up" style="animation-delay: 0.2s">
        {subtitle}
      </p>
    )}
  </div>
</section>
