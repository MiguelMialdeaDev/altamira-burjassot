---
/**
 * Previews para la homepage: 3 cards de Historia / Carta / Reseñas
 * Llevan al usuario a explorar las páginas dedicadas.
 */
import { url, RESTAURANT } from '../data/config';
import { featuredItems } from '../data/menu';

const featured = featuredItems().slice(0, 3);
---

<!-- Quick teaser sections -->
<section class="py-20 bg-cream">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">

      <!-- Card Historia -->
      <a href={url('/historia/')} class="group block bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
        <div class="aspect-video bg-[url('https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80')] bg-cover bg-center"></div>
        <div class="p-6">
          <p class="text-tropical-mango font-medium tracking-widest uppercase text-xs mb-2">Nuestra historia</p>
          <h3 class="font-display text-2xl font-bold text-charcoal mb-3 group-hover:text-tropical-mango transition-colors">
            De Caracas a Burjassot
          </h3>
          <p class="text-charcoal/70 text-sm leading-relaxed mb-4">
            Tres ciudades. Una misma cocina. Conoce el camino que nos trajo hasta aquí.
          </p>
          <span class="inline-flex items-center gap-1 text-tropical-tierra font-bold text-sm">
            Leer más
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </div>
      </a>

      <!-- Card Carta -->
      <a href={url('/carta/')} class="group block bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
        <div class="aspect-video bg-[url('https://images.unsplash.com/photo-1565299507177-b0ac66763828?w=600&q=80')] bg-cover bg-center"></div>
        <div class="p-6">
          <p class="text-tropical-mango font-medium tracking-widest uppercase text-xs mb-2">La carta</p>
          <h3 class="font-display text-2xl font-bold text-charcoal mb-3 group-hover:text-tropical-mango transition-colors">
            Sabores de Venezuela
          </h3>
          <p class="text-charcoal/70 text-sm leading-relaxed mb-4">
            Cachapas, arepas, pabellón criollo, tequeños. Producto fresco y recetas honestas.
          </p>
          <span class="inline-flex items-center gap-1 text-tropical-tierra font-bold text-sm">
            Ver la carta
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </div>
      </a>

      <!-- Card Reseñas -->
      <a href={url('/resenas/')} class="group block bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
        <div class="aspect-video bg-gradient-to-br from-tropical-tierra via-charcoal to-tropical-jungla flex items-center justify-center relative">
          <div class="text-center">
            <div class="flex justify-center mb-2">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-7 h-7 text-tropical-mango" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-cream font-black text-3xl font-display">{RESTAURANT.rating.value}</p>
            <p class="text-cream/70 text-xs">en Google · {RESTAURANT.rating.count}+ reseñas</p>
          </div>
        </div>
        <div class="p-6">
          <p class="text-tropical-mango font-medium tracking-widest uppercase text-xs mb-2">Lo que dicen</p>
          <h3 class="font-display text-2xl font-bold text-charcoal mb-3 group-hover:text-tropical-mango transition-colors">
            Reseñas reales
          </h3>
          <p class="text-charcoal/70 text-sm leading-relaxed mb-4">
            "Como en casa de mi abuela", "directo a Caracas", "merece la pena cada minuto"...
          </p>
          <span class="inline-flex items-center gap-1 text-tropical-tierra font-bold text-sm">
            Leer reseñas
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- CTA banda inferior: Encuéntranos / Reservar -->
<section class="py-20 bg-gradient-to-br from-tropical-tierra via-charcoal to-tropical-jungla relative overflow-hidden">
  <div class="absolute inset-0 opacity-10"
       style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;">
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-display text-4xl md:text-5xl font-black text-cream mb-4">
        Ven a probar Venezuela
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-2xl mx-auto">
        Somos un sitio pequeño, en zona discreta. Reservar nos ayuda a cuidarte mejor.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={url('/reservar/')}
          class="inline-flex items-center justify-center gap-2 bg-tropical-mango hover:bg-tropical-mango/90 text-charcoal font-bold px-8 py-4 rounded-full shadow-2xl transition-all"
        >
          Reservar mesa
        </a>
        <a
          href={url('/encuentranos/')}
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/30 text-white font-medium px-8 py-4 rounded-full transition-all"
        >
          Cómo llegar
        </a>
      </div>
    </div>
  </div>
</section>
