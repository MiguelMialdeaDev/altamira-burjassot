---
import { url, RESTAURANT } from '../data/config';
---

<!-- Historia teaser con imagen + caja Nuestra Ruta superpuesta -->
<section class="py-20 bg-cream">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">

      <!-- Texto -->
      <div class="order-2 lg:order-1">
        <p class="text-tropical-mango font-medium tracking-widest uppercase text-xs mb-3">Quiénes somos</p>
        <h2 class="font-display text-4xl md:text-5xl font-black text-charcoal leading-tight mb-6">
          Venimos de Caracas.
        </h2>
        <p class="text-charcoal/70 text-lg leading-relaxed mb-8">
          Empezamos en Buenos Aires en 2019. Ahora estamos en Burjassot.
          Lo único que no cambió fue la cocina.
        </p>
        <a
          href={url('/historia/')}
          class="inline-flex items-center gap-2 text-tropical-tierra hover:text-tropical-mango font-bold group"
        >
          Leer la historia completa
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Imagen con caja Nuestra Ruta superpuesta -->
      <div class="order-1 lg:order-2">
        <div class="relative">
          <!-- Imagen ambiente -->
          <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl bg-[url('https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80')] bg-cover bg-center">
          </div>

          <!-- Caja Nuestra Ruta superpuesta -->
          <div class="absolute -bottom-6 -left-6 bg-tropical-jungla rounded-2xl shadow-2xl p-6 max-w-xs text-cream border border-tropical-mango/20">
            <p class="text-tropical-mango text-xs uppercase tracking-widest font-bold mb-4">Nuestra ruta</p>
            <ol class="space-y-3 text-sm">
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-venezuela-yellow rounded-full flex-shrink-0"></span>
                <span class="font-bold">Caracas</span>
                <span class="text-cream/50 text-xs">· origen</span>
              </li>
              <li class="ml-1 w-px h-3 bg-cream/20"></li>
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-tropical-mango rounded-full flex-shrink-0"></span>
                <span class="font-bold">Buenos Aires</span>
                <span class="text-cream/50 text-xs">· 2019</span>
              </li>
              <li class="ml-1 w-px h-3 bg-cream/20"></li>
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-cream rounded-full flex-shrink-0"></span>
                <span class="font-bold">Burjassot</span>
                <span class="text-cream/50 text-xs">· hoy</span>
              </li>
            </ol>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Carta + Reseñas en banda dividida -->
<section class="bg-white border-t border-charcoal/5">
  <div class="container mx-auto grid md:grid-cols-2">

    <!-- Carta -->
    <a href={url('/carta/')} class="group block p-10 md:p-16 border-r-0 md:border-r border-b md:border-b-0 border-charcoal/10 hover:bg-cream transition-colors">
      <p class="text-tropical-mango font-medium tracking-widest uppercase text-xs mb-3">La carta</p>
      <h3 class="font-display text-3xl md:text-4xl font-black text-charcoal mb-4 group-hover:text-tropical-mango transition-colors">
        Cachapas, arepas y pabellón criollo
      </h3>
      <p class="text-charcoal/60 mb-6">
        Más de 15 platos venezolanos. Tequeños recién hechos, quesillo casero, papelón con limón.
      </p>
      <span class="inline-flex items-center gap-1 text-tropical-tierra font-bold text-sm">
        Ver la carta completa
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>

    <!-- Reseñas -->
    <a href={url('/resenas/')} class="group block p-10 md:p-16 hover:bg-cream transition-colors">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-4 h-4 text-tropical-mango" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="font-bold text-charcoal">{RESTAURANT.rating.value}</span>
        <span class="text-charcoal/50 text-sm">· {RESTAURANT.rating.count}+ reseñas</span>
      </div>
      <h3 class="font-display text-3xl md:text-4xl font-black text-charcoal mb-4 group-hover:text-tropical-mango transition-colors">
        Lo que dicen en Google
      </h3>
      <p class="text-charcoal/60 mb-6">
        Reseñas reales de quienes ya nos han visitado.
      </p>
      <span class="inline-flex items-center gap-1 text-tropical-tierra font-bold text-sm">
        Ver reseñas
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>

  </div>
</section>

<!-- CTA reservar - sobrio -->
<section class="py-24 bg-charcoal">
  <div class="container mx-auto px-6 text-center max-w-3xl">
    <h2 class="font-display text-4xl md:text-5xl font-black text-cream mb-6">
      Reserva si vienes el fin de semana
    </h2>
    <p class="text-cream/70 mb-10">
      Somos pequeños. Si reservas, nos organizamos.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={url('/reservar/')}
        class="inline-flex items-center justify-center bg-tropical-mango hover:bg-tropical-mango/90 text-charcoal font-bold px-8 py-4 rounded-full transition-all"
      >
        Reservar
      </a>
      <a
        href={url('/encuentranos/')}
        class="inline-flex items-center justify-center border border-cream/30 text-cream hover:bg-cream/10 font-medium px-8 py-4 rounded-full transition-all"
      >
        Cómo llegar
      </a>
    </div>
  </div>
</section>
