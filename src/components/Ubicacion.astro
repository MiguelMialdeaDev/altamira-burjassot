---
import { RESTAURANT, whatsappLink } from '../data/config';

const horarios = [
  { dia: 'Lunes a Viernes', morning: '10:00 — 16:00', evening: '19:30 — 23:00' },
  { dia: 'Sábado y Domingo', morning: '09:00 — 16:00', evening: '19:00 — 23:30' },
];
---

<section id="ubicacion" class="py-24 bg-cream">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
      <!-- Info -->
      <div class="space-y-8">
        <!-- Dirección -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-tropical-mango/10">
          <div class="flex items-start gap-4 mb-6">
            <div class="bg-tropical-mango/20 p-3 rounded-xl">
              <svg class="w-6 h-6 text-tropical-tierra" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-display text-xl font-bold text-charcoal mb-1">Dirección</h3>
              <p class="text-charcoal/80">
                {RESTAURANT.address}<br />
                {RESTAURANT.postalCode} {RESTAURANT.city}, {RESTAURANT.region}
              </p>
              <a
                href={RESTAURANT.links.googleMaps}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1 text-tropical-tierra hover:text-tropical-mango font-bold text-sm mt-3 group"
              >
                Abrir en Google Maps
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-start gap-4 mb-6 pt-6 border-t border-charcoal/10">
            <div class="bg-tropical-mango/20 p-3 rounded-xl">
              <svg class="w-6 h-6 text-tropical-tierra" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-display text-xl font-bold text-charcoal mb-1">Teléfono</h3>
              <a href={`tel:${RESTAURANT.phoneE164}`} class="text-charcoal/80 hover:text-tropical-mango font-medium">
                {RESTAURANT.phoneDisplay}
              </a>
              <p class="text-charcoal/60 text-sm mt-1">Reserva con antelación, somos pequeños</p>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="pt-6 border-t border-charcoal/10">
            <p class="text-charcoal/70 text-sm mb-3">
              <strong>¿Te pierdes?</strong> Escríbenos por WhatsApp y te orientamos al momento.
            </p>
            <a
              href={whatsappLink('¡Hola! No encuentro vuestro restaurante, ¿podríais ayudarme?')}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-5 py-2.5 rounded-full text-sm transition-all hover:-translate-y-0.5"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/>
              </svg>
              Escribir por WhatsApp
            </a>
          </div>
        </div>

        <!-- Horarios -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-tropical-mango/10">
          <div class="flex items-start gap-4 mb-6">
            <div class="bg-tropical-mango/20 p-3 rounded-xl">
              <svg class="w-6 h-6 text-tropical-tierra" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h3 class="font-display text-xl font-bold text-charcoal mb-1">Horarios</h3>
              <p class="text-charcoal/60 text-sm">Abrimos todos los días</p>
            </div>
          </div>

          <div class="space-y-3">
            {horarios.map(h => (
              <div class="flex flex-wrap items-baseline justify-between gap-3 pb-3 border-b border-charcoal/5 last:border-0">
                <div class="font-bold text-charcoal">{h.dia}</div>
                <div class="text-charcoal/70 text-sm font-medium">
                  {h.morning} <span class="text-charcoal/40 mx-1">·</span> {h.evening}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="rounded-2xl overflow-hidden shadow-2xl h-full min-h-[500px] border border-tropical-mango/10">
        <iframe
          src={`https://maps.google.com/maps?q=${RESTAURANT.coordinates.lat},${RESTAURANT.coordinates.lng}&t=&z=17&ie=UTF8&iwloc=&output=embed`}
          width="100%"
          height="100%"
          style="border:0; min-height: 500px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa de Altamira GCP"
        ></iframe>
      </div>
    </div>
  </div>
</section>
