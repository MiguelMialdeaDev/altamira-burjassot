---
import { CATEGORIES, itemsByCategory, featuredItems } from '../data/menu';
import { RESTAURANT } from '../data/config';

const featured = featuredItems();
---

<section id="carta" class="py-24 bg-cream">
  <div class="container mx-auto px-6">
    <!-- Destacados -->
    {featured.length > 0 && (
      <div class="mb-20">
        <h3 class="font-display text-2xl font-bold text-tropical-tierra mb-8 max-w-5xl mx-auto">
          Lo más pedido
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {featured.map(item => (
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 border border-tropical-mango/10 relative">
              {item.badge && (
                <div class="absolute -top-3 left-6 bg-tropical-mango text-charcoal text-xs font-bold px-3 py-1 rounded-full shadow-md">
                  {item.badge}
                </div>
              )}
              <div class="flex items-start justify-between mb-2 mt-2">
                <h4 class="font-display text-xl font-bold text-charcoal">{item.name}</h4>
                <span class="font-bold text-tropical-mango text-xl whitespace-nowrap ml-2">
                  {item.price.toFixed(2)}€
                </span>
              </div>
              <p class="text-charcoal/70 text-sm mb-4">{item.description}</p>
              <div class="flex flex-wrap gap-2">
                {item.vegetarian && (
                  <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full font-medium">Vegetariano</span>
                )}
                {item.glutenFree && (
                  <span class="text-xs bg-tropical-maiz/30 text-tropical-tierra px-2 py-1 rounded-full font-medium">Sin gluten</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Categorías completas -->
    <div class="max-w-5xl mx-auto">
      {CATEGORIES.map(cat => {
        const items = itemsByCategory(cat.id);
        if (items.length === 0) return null;

        return (
          <div class="mb-12">
            <div class="border-b-2 border-tropical-mango/30 pb-3 mb-6">
              <h3 class="font-display text-2xl font-bold text-charcoal">
                {cat.label}
              </h3>
              {cat.description && (
                <p class="text-charcoal/60 text-sm mt-1 italic">{cat.description}</p>
              )}
            </div>
            <div class="grid md:grid-cols-2 gap-x-12 gap-y-6">
              {items.map(item => (
                <div class="flex items-start justify-between gap-4 group">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      <h4 class="font-bold text-charcoal group-hover:text-tropical-mango transition-colors">
                        {item.name}
                      </h4>
                      {item.vegetarian && <span class="text-[10px] text-green-700 font-bold uppercase tracking-wider border border-green-700/30 px-1.5 py-0.5 rounded">Veg</span>}
                      {item.glutenFree && <span class="text-[10px] text-tropical-tierra font-bold uppercase tracking-wider border border-tropical-tierra/30 px-1.5 py-0.5 rounded">SG</span>}
                    </div>
                    <p class="text-charcoal/60 text-sm leading-snug">{item.description}</p>
                  </div>
                  <div class="font-display font-bold text-tropical-mango text-lg whitespace-nowrap">
                    {item.price.toFixed(2)}€
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <!-- CTA delivery -->
    <div class="mt-20 text-center bg-tropical-jungla/5 rounded-3xl py-12 px-6">
      <p class="text-charcoal/80 mb-2 font-medium">¿Prefieres comer en casa?</p>
      <p class="text-charcoal/60 text-sm mb-6">Pídelo a domicilio</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={RESTAURANT.links.glovo}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-[#FFC244] hover:bg-[#f0b32e] text-charcoal font-bold px-6 py-3 rounded-full transition-all hover:-translate-y-0.5 shadow-lg"
        >
          Pedir en Glovo
        </a>
        <a
          href={RESTAURANT.links.ubereats}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-black hover:bg-gray-800 text-white font-bold px-6 py-3 rounded-full transition-all hover:-translate-y-0.5 shadow-lg"
        >
          Pedir en Uber Eats
        </a>
      </div>
    </div>

    <!-- Disclaimer alérgenos -->
    <div class="mt-12 text-center max-w-2xl mx-auto">
      <p class="text-xs text-charcoal/50">
        Información sobre alérgenos disponible bajo solicitud.
        Si tienes alergias o intolerancias, avísanos al hacer la reserva.
      </p>
    </div>
  </div>
</section>
