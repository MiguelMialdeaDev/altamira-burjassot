---
import FlagVE from './FlagVE.astro';
import { SECTIONS, RESTAURANT, url } from '../data/config';

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  // Normalizar para comparar con base path
  const fullPath = url(path);
  if (path === '/') return currentPath === fullPath || currentPath === fullPath + '/' || currentPath.replace(/\/$/, '') === fullPath.replace(/\/$/, '');
  return currentPath.startsWith(fullPath.replace(/\/$/, ''));
};
---

<nav class="sticky top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-md shadow-sm border-b border-charcoal/5">
  <div class="container mx-auto px-6 py-3">
    <div class="flex items-center justify-between">
      <a href={url('/')} class="font-display text-2xl font-black text-charcoal hover:text-tropical-mango transition-colors flex items-center gap-2">
        <img src={`${import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/"}logo-altamira.jpg`} alt="Logo Altamira GCP" class="h-9 w-auto rounded-md shadow-sm" />
        {RESTAURANT.shortName}
      </a>

      <ul class="hidden lg:flex items-center gap-1">
        {SECTIONS.filter(s => s.id !== 'reservar').map(section => (
          <li>
            <a
              href={url(section.path)}
              class={`text-sm font-medium px-4 py-2 rounded-full transition-all ${isActive(section.path) ? 'text-tropical-tierra bg-tropical-mango/15' : 'text-charcoal/70 hover:text-tropical-mango hover:bg-tropical-mango/10'}`}
            >
              {section.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <!-- Teléfono visible en desktop -->
        <a
          href={`tel:${RESTAURANT.phoneE164}`}
          class="hidden lg:inline-flex items-center gap-1.5 text-charcoal/80 hover:text-tropical-mango font-medium text-sm px-3 py-2 transition-colors"
        >
          <svg class="w-4 h-4 text-tropical-mango" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          {RESTAURANT.phoneDisplay}
        </a>

        <a
          href={url('/reservar/')}
          class="bg-tropical-mango hover:bg-tropical-tierra text-charcoal hover:text-cream font-bold text-sm px-5 py-2 rounded-full transition-all"
        >
          Reservar
        </a>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-charcoal hover:text-tropical-mango" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu drawer -->
    <div id="mobile-menu" class="lg:hidden hidden mt-4 pb-2 border-t border-charcoal/10 pt-4">
      <ul class="flex flex-col gap-1">
        {SECTIONS.filter(s => s.id !== 'reservar').map(section => (
          <li>
            <a
              href={url(section.path)}
              class={`block text-sm font-medium px-4 py-3 rounded-lg transition-all ${isActive(section.path) ? 'text-tropical-tierra bg-tropical-mango/15' : 'text-charcoal/70 hover:bg-tropical-mango/10'}`}
            >
              {section.label}
            </a>
          </li>
        ))}
        <li class="mt-2 pt-3 border-t border-charcoal/10">
          <a
            href={`tel:${RESTAURANT.phoneE164}`}
            class="flex items-center gap-2 text-sm font-medium px-4 py-3 rounded-lg text-charcoal/80 hover:bg-tropical-mango/10 hover:text-tropical-mango transition-all"
          >
            <svg class="w-4 h-4 text-tropical-mango" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Llámanos · {RESTAURANT.phoneDisplay}
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
  });
</script>
