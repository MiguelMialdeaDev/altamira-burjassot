---
import { SECTIONS, RESTAURANT } from '../data/config';
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <div class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between bg-white/90 backdrop-blur-md rounded-full px-6 py-3 shadow-lg border border-white/40">
      <a href="#inicio" class="font-display text-xl font-black text-charcoal hover:text-tropical-mango transition-colors">
        {RESTAURANT.shortName}
      </a>
      <ul class="hidden md:flex items-center gap-1">
        {SECTIONS.map(section => (
          <li>
            <a
              href={`#${section.id}`}
              class="text-charcoal/70 hover:text-tropical-mango hover:bg-tropical-mango/10 font-medium text-sm px-4 py-2 rounded-full transition-all"
            >
              {section.label}
            </a>
          </li>
        ))}
      </ul>
      <a
        href={`tel:${RESTAURANT.phone}`}
        class="bg-tropical-mango hover:bg-tropical-tierra text-charcoal hover:text-cream font-bold text-sm px-5 py-2 rounded-full transition-all"
      >
        Reservar
      </a>
    </div>
  </div>
</nav>

<script>
  // Nav transparency on scroll
  const nav = document.getElementById('navbar');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        nav.classList.add('translate-y-0');
      }
    });
  }
</script>
